  "keyFeatures": [
    "80+ curated Docker images for popular open-source tools",
    "Automated rebuilds triggered one hour after upstream releases via GitHub Actions",
    "Multi-stage builds with minimal final image sizes",
    "Hardened binaries and non-root user execution",
    "Daily security scanning with Trivy, Snyk, and Anchore",
    "Image signing and SBOM (Software Bill of Materials) generation",
    "Pinned base image digests for reproducible builds",
    "Multi-architecture support (amd64, arm64, and more)",
    "Available on both GitHub Container Registry (ghcr.io) and Docker Hub",
    "OpenSSF Security Scorecard compliance with Allstar enforcement"
  ],
  "publicApiSurface": [
